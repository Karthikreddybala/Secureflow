# ─────────────────────────────────────────────────────────────
# SecureFlow Frontend — Environment Variables
# Copy to .env.production and fill in real values before building.
# NEVER commit .env.production with real URLs to version control.
# ─────────────────────────────────────────────────────────────

# URL of the Node.js auth backend
# e.g. VITE_API_URL=https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Base URL for WebSocket connections  (ML/Daphne backend)
# e.g. VITE_WS_BASE_URL=wss://ml.yourdomain.com
VITE_WS_BASE_URL=ws://localhost:8000
