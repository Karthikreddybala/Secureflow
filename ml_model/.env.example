# ─────────────────────────────────────────────────────────────
# SecureFlow ML Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Django secret key — generate a new one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts / domains
# e.g. DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Redis URL for WebSocket channel layers (required for multi-worker production)
# Leave empty to use InMemoryChannelLayer (single-worker / local dev only)
# e.g. REDIS_URL=redis://localhost:6379
REDIS_URL=

# Comma-separated allowed CORS origins (leave empty to allow all — dev only)
# e.g. CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGINS=
